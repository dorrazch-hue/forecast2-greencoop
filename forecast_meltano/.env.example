# Copier ce fichier en .env et remplir les valeurs
# Ce fichier est versionné (sans secrets)
# Le fichier .env est exclu du dépôt via .gitignore

# Token API InfoClimat (obligatoire pour Meltano et load_infoclimat_api.py)
TAP_INFOCLIMAT_TOKEN=votre_token_infoclimat_ici

# Fenêtre de dates demandée à l'API InfoClimat (format AAAA-MM-JJ)
# Utilisée par meltano.yml et load_infoclimat_api.py
INFOCLIMAT_START=2026-07-01
INFOCLIMAT_END=2026-07-08

# Mot de passe AWS RDS (obligatoire pour dbt --target prod et migrate_to_rds.py)
RDS_PASSWORD=votre_mdp_rds_ici

# Mot de passe PostgreSQL local Docker (optionnel, defaut: forecast_pass)
# LOCAL_DB_PASSWORD=forecast_pass
